# Copy to .env.local and fill in real values. .env.local is gitignored — never commit it.
# Get these from your Supabase project: Settings -> API.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Service-role key bypasses RLS. As of M3 it IS used — but only by
# src/app/api/stripe/webhook/route.ts, which runs server-to-server with no
# user session to authenticate as. Never let this touch a client bundle.
# SUPABASE_SERVICE_ROLE_KEY=

# Get this from console.anthropic.com. Server-side only — NEVER expose to the
# client. Model is locked to claude-sonnet-4-6 (Decision Log #7 / Golden Test Run 01).
# ANTHROPIC_API_KEY=

# Stripe — Settings/Developers in the Stripe Dashboard. Test mode keys (sk_test_...)
# for local dev. STRIPE_WEBHOOK_SECRET comes from `stripe listen` locally, or the
# Dashboard's webhook endpoint config in production.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Two Prices under one "WholeClaim Pro" Product (Decision Log #16 — Open,
# A/B testing $49 one-time vs $19/month; do not pick one, both must exist).
# STRIPE_PRICE_ONETIME=
# STRIPE_PRICE_SUBSCRIPTION=

# M5: web push for deadline reminders. Generate a pair with
# `npx web-push generate-vapid-keys` — one pair per environment (dev vs prod
# should NOT share keys, since browsers pin subscriptions to the public key).
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:replace-with-a-real-contact-address

# Shared secret the deadline-check cron route checks for in an
# Authorization: Bearer header, so only Vercel Cron (or you) can trigger it.
# CRON_SECRET=

# M4: Resend, for the Claim Grade results email. Requires a Resend account
# (resend.com) and a verified sending domain — domain depends on Decision
# Log #17 (name clearance), still Open. Without a verified domain, leave
# RESEND_FROM_EMAIL unset to fall back to Resend's shared test sender.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
