# Copy to .env.local and fill in real values. .env.local is gitignored — never commit it.
# Get these from your Supabase project: Settings -> API.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Service-role key is NOT used by any M1 app code path (CRUD relies on RLS
# via the anon key + user session). Only add it later for admin scripts/
# migrations that intentionally need to bypass RLS.
# SUPABASE_SERVICE_ROLE_KEY=

# Get this from console.anthropic.com. Server-side only — NEVER expose to the
# client. Model is locked to claude-sonnet-4-6 (Decision Log #7 / Golden Test Run 01).
# ANTHROPIC_API_KEY=
